{
  "domain": "alpicool_fridge",
  "name": "Alpicool / ICECO Fridge (BLE)",
  "codeowners": ["@david"],
  "config_flow": true,
  "dependencies": ["bluetooth_adapters"],
  "bluetooth": [
    { "local_name": "A1-*" },
    { "local_name": "AK1-*" },
    { "local_name": "AK2-*" },
    { "local_name": "AK3-*" },
    { "local_name": "WT-*" }
  ],
  "documentation": "https://github.com/jakub-hajek/alpicool-esp32-mqtt",
  "iot_class": "local_polling",
  "requirements": ["bleak-retry-connector>=3.5.0"],
  "version": "0.3.2"
}
